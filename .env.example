# Скопируйте в системные переменные окружения пользователя или задайте в профиле shell.
# Cursor подставляет ${env:...} из окружения процесса IDE (не из .env файла автоматически для mcp.json).
#
# Stitch MCP (Google API key для X-Goog-Api-Key)
STITCH_GOOGLE_API_KEY=

# --- InterLex / деплой (опционально, см. docs/deploy/coolify.md)
# Канонический URL сайта на этом инстансе (metadata, абсолютные ссылки):
# NEXT_PUBLIC_SITE_URL=https://interlex.ge
# NEXT_PUBLIC_SITE_URL=https://interlex.kz
#
# Логика инстансов: host → interlex.ge (EN), hostkz → interlex.kz (RU).
# Если за прокси не видно публичного Host, задайте явно:
# INTERLEX_INSTANCE=ge
# INTERLEX_INSTANCE=kz
